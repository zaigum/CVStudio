# CVStudio Environment Variables

# App Configuration
VITE_APP_NAME=CVStudio
VITE_APP_VERSION=1.0.0

# PDF.js Worker URL (optional - uses CDN by default)
# VITE_PDFJS_WORKER_URL=https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.168/pdf.worker.min.mjs

# Maximum file size for PDF upload (in bytes)
# Default: 10MB
VITE_MAX_FILE_SIZE=10485760

# Enable debug mode
VITE_DEBUG=false
